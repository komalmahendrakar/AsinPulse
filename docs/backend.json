
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data including job configurations.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user" },
        "status": { "type": "string", "enum": ["active", "suspended"], "default": "active" },
        "subscription_plan": { "type": "string", "enum": ["starter", "agency", "enterprise"] },
        "created_at": { "type": "string", "format": "date-time" },
        "monitoring_frequency": { "type": "string", "default": "hourly" },
        "sales_check_time": { "type": "string", "default": "00:00" },
        "last_sync_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "email"]
    },
    "ASIN": {
      "title": "ASIN",
      "description": "Amazon Standard Identification Number monitored by a user.",
      "type": "object",
      "properties": {
        "asin_id": { "type": "string" },
        "user_id": { "type": "string" },
        "asin_code": { "type": "string" },
        "product_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "asin_code"]
    },
    "Product": {
      "title": "Product",
      "description": "Live Amazon product details and performance cache.",
      "type": "object",
      "properties": {
        "asin": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "stock": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["asin", "title"]
    },
    "MonitoringData": {
      "title": "MonitoringData",
      "description": "Historical snapshots of product signals.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "asin_code": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "buybox_owner": { "type": "string" },
        "delivery_days": { "type": "number" },
        "rating": { "type": "number" }
      },
      "required": ["user_id", "asin_code", "timestamp"]
    },
    "SalesData": {
      "title": "SalesData",
      "description": "Historical sales performance for an ASIN.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "asin_code": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "units_sold": { "type": "number" },
        "revenue": { "type": "number" }
      },
      "required": ["user_id", "asin_code", "date"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Detected issues or sales drops.",
      "type": "object",
      "properties": {
        "alert_id": { "type": "string" },
        "user_id": { "type": "string" },
        "asin_code": { "type": "string" },
        "alert_type": { "type": "string", "enum": ["SALES_DROP", "OPERATIONAL"] },
        "reason": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "asin_code", "alert_type", "timestamp"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Audit trail for system events and job executions.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "event_type": { "type": "string", "enum": ["JOB_START", "JOB_COMPLETE", "ALERT_CREATED", "FUNCTION_ERROR", "EMAIL_FAILURE"] },
        "description": { "type": "string" },
        "function_name": { "type": "string" },
        "alert_id": { "type": "string" }
      },
      "required": ["user_id", "timestamp", "event_type", "description"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Outbound email queue for Trigger Email extension",
      "type": "object",
      "properties": {
        "to": { "type": "string" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "text": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "UsageMetrics": {
      "title": "UsageMetrics",
      "description": "Daily platform usage statistics for a user.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "number_of_asins_monitored": { "type": "number" },
        "alerts_generated": { "type": "number" },
        "monitoring_runs": { "type": "number" }
      },
      "required": ["user_id", "date"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/asins/{asinId}": {
      "schema": "ASIN",
      "description": "Monitored ASINs"
    },
    "/products/{asin}": {
      "schema": "Product",
      "description": "Amazon product details"
    },
    "/monitoring_data/{dataId}": {
      "schema": "MonitoringData",
      "description": "Global periodic snapshots of ASIN performance"
    },
    "/sales_data/{dataId}": {
      "schema": "SalesData",
      "description": "Global daily sales data"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "System generated alerts"
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "System audit and error logs"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Outbound email queue"
    },
    "/usage_metrics/{metricId}": {
      "schema": "UsageMetrics",
      "description": "Daily usage tracking"
    }
  }
}
